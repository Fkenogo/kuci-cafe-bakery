{
  "entities": {
    "RestaurantSettings": {
      "title": "Restaurant Settings",
      "description": "Global settings for the restaurant",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" },
        "active": { "type": "boolean" },
        "contactInfo": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "whatsapp": { "type": "string" },
            "email": { "type": "string" },
            "location": { "type": "string" },
            "mapLink": { "type": "string" },
            "contactPerson": { "type": "string" },
            "momoPayCode": { "type": "string" },
            "momoMerchantName": { "type": "string" },
            "hours": { "type": "string" }
          }
        },
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "text": { "type": "string" },
            "bg": { "type": "string" },
            "bgSecondary": { "type": "string" }
          }
        },
        "extraCosts": {
          "type": "object",
          "properties": {
            "topping": { "type": "integer" },
            "otherExtra": { "type": "integer" }
          }
        },
        "deliveryOptions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "area": { "type": "string" },
              "fee": { "type": "integer" },
              "estimatedTime": { "type": "string" }
            }
          }
        },
        "paymentMethods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "socialLinks": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "customizationOptions": {
          "type": "object",
          "properties": {
            "sides": { "type": "array", "items": { "type": "string" } },
            "pizzaToppings": { "type": "array", "items": { "type": "string" } },
            "breakfastToppings": { "type": "array", "items": { "type": "string" } },
            "burritoFillings": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "Category": {
      "title": "Category",
      "description": "A menu category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "sortOrder": { "type": "integer" },
        "active": { "type": "boolean" },
        "iconName": { "type": "string" }
      },
      "required": ["name", "slug", "active"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "A single item on the menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "tagline": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "basePrice": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "active": { "type": "boolean" },
        "available": { "type": "boolean" },
        "station": { "type": "string", "enum": ["kitchen", "bakery", "bar", "coffee"] },
        "itemType": { "type": "string", "enum": ["simple", "variant", "customizable", "combo"] },
        "featured": { "type": "boolean" },
        "sortOrder": { "type": "integer" },
        "note": { "type": "string" },
        "averageRating": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "integer" },
              "active": { "type": "boolean" },
              "description": { "type": "string" },
              "isDefault": { "type": "boolean" }
            }
          }
        },
        "modifierGroups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "selectionType": { "type": "string", "enum": ["single", "multiple"] },
              "required": { "type": "boolean" },
              "minSelections": { "type": "integer" },
              "maxSelections": { "type": "integer" },
              "includedInPrice": { "type": "boolean" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "priceDelta": { "type": "integer" },
                    "active": { "type": "boolean" },
                    "description": { "type": "string" },
                    "isDefault": { "type": "boolean" },
                    "tags": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        },
        "reviews": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "user": { "type": "string" },
              "rating": { "type": "integer" },
              "comment": { "type": "string" },
              "date": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "categoryId", "basePrice", "active", "available", "station", "itemType"]
    }
  },
  "firestore": {
    "settings/restaurant": {
      "schema": "RestaurantSettings",
      "description": "Global restaurant settings"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of menu categories"
    },
    "menuItems": {
      "schema": "MenuItem",
      "description": "Collection of menu items"
    }
  }
}
